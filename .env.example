# COBRA frontend env (Next.js). Copy to .env for local dev:  cp .env.example .env
#
# Base URL of the Flask backend that the /api/* routes proxy to (next.config.js
# rewrites). Server-side only — never exposed to the browser.
#
#   Local dev : http://localhost:8001
#   Vercel    : set COBRA_BACKEND in Project Settings → Environment Variables to
#               your deployed Render backend, e.g. https://cobra-xxxx.onrender.com
#
# NOTE: the rewrites are baked at BUILD time, so changing this on Vercel needs a
# redeploy. A value set in Vercel's dashboard overrides this file.
COBRA_BACKEND=http://localhost:8001
